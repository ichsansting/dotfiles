[user]
	name = Ichsan Sting
	email = 139094570+ichsansting@users.noreply.github.com
	signingkey = ~/.ssh/id_ed25519

[gpg]
	format = ssh

# ponytail: allowedSignersFile isn't auto-derived from id_ed25519 on launch
# (dotfiles-old's activate.py pubkey step wasn't ported); verify-commit needs
# the file populated by hand until a launch-time derivation step exists.
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign = true

[pull]
	rebase = true

[init]
	defaultBranch = main

[core]
	excludesfile = ~/.config/git/ignore
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	features = side-by-side line-numbers
	syntax-theme = Catppuccin Mocha

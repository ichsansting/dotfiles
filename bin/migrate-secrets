#!/usr/bin/env bash
# One-time real-content migration (ticket 16): decrypts every secret
# ~/dotfiles-old tracks and re-encrypts it in this repo's binary sops format
# at its new bundle path, replaces the demo-only identity.age with the real
# one, and captures atuin's session/key (never tracked anywhere before) as a
# fresh secret. Run this yourself, locally, where you can type the real age
# passphrase on a real terminal — it is never passed through an agent.
#
# Usage: bin/migrate-secrets [OLD_REPO]   (defaults to ~/dotfiles-old)
#
# Nothing decrypted is ever printed; only per-item progress/success lines.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OLD_REPO="${1:-$HOME/dotfiles-old}"

for bin in age age-keygen sops; do
  command -v "$bin" >/dev/null || { echo "migrate-secrets: $bin not on PATH — try: nix shell nixpkgs#age nixpkgs#sops" >&2; exit 1; }
done

[[ -f "$OLD_REPO/identity.age" ]] || { echo "migrate-secrets: no identity.age at $OLD_REPO" >&2; exit 1; }
[[ -f "$ROOT/.sops.yaml" ]] || { echo "migrate-secrets: $ROOT/.sops.yaml missing" >&2; exit 1; }

RECIPIENT="$(grep -A1 '^keys:' "$ROOT/.sops.yaml" | tail -1 | sed 's/^[^&]*&identity //')"
[[ -n "$RECIPIENT" ]] || { echo "migrate-secrets: could not read age recipient from $ROOT/.sops.yaml" >&2; exit 1; }

WORKDIR="$(mktemp -d)"
cleanup() { [[ -f "$WORKDIR/keys.txt" ]] && shred -u "$WORKDIR/keys.txt" 2>/dev/null; rm -rf "$WORKDIR"; }
trap cleanup EXIT

echo "Decrypting $OLD_REPO/identity.age — type its passphrase:"
age --decrypt -o "$WORKDIR/keys.txt" "$OLD_REPO/identity.age"
chmod 600 "$WORKDIR/keys.txt"

migrate_one() {
  local old_file="$1" new_path="$2" key="$3"
  [[ -f "$old_file" ]] || { echo "  SKIP (not found): $old_file"; return; }
  SOPS_AGE_KEY_FILE="$WORKDIR/keys.txt" sops --decrypt --extract "[\"$key\"]" "$old_file" > "$WORKDIR/plain"
  mkdir -p "$ROOT/$(dirname "$new_path")"
  sops --encrypt --config /dev/null --age "$RECIPIENT" --input-type binary --output-type binary "$WORKDIR/plain" > "$ROOT/$new_path"
  shred -u "$WORKDIR/plain"
  echo "  OK -> $new_path"
}

echo "Migrating tracked secrets:"
migrate_one "$OLD_REPO/modules/vcs/files/.ssh/id_ed25519.sops.yaml" "bundles/vcs/files/.ssh/id_ed25519" "id_ed25519"
migrate_one "$OLD_REPO/modules/vcs/files/.config/gh/hosts.yml.sops.yaml" "bundles/vcs/files/.config/gh/hosts.yml" "hosts.yml"
migrate_one "$OLD_REPO/modules/work/files/.aws/config.sops.yaml" "bundles/work-tools/files/.aws/config" "config"
migrate_one "$OLD_REPO/modules/work/files/.config/fish/conf.d/traveloka-secrets.fish.sops.yaml" "bundles/work-tools/files/.config/fish/conf.d/60-traveloka-secrets.fish" "traveloka-secrets.fish"
migrate_one "$OLD_REPO/modules/claude-oauth/files/.claude/.credentials.json.sops.yaml" "bundles/claude-oauth/files/.claude/.credentials.json" ".credentials.json"

echo "Capturing atuin session/key (new — never tracked in dotfiles-old):"
ATUIN_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/atuin"
mkdir -p "$ROOT/bundles/terminal/files/.local/share/atuin"
for f in key session; do
  if [[ -f "$ATUIN_DIR/$f" ]]; then
    sops --encrypt --config /dev/null --age "$RECIPIENT" --input-type binary --output-type binary "$ATUIN_DIR/$f" \
      > "$ROOT/bundles/terminal/files/.local/share/atuin/$f"
    echo "  OK -> bundles/terminal/files/.local/share/atuin/$f"
  else
    echo "  SKIP (not found: $ATUIN_DIR/$f — run 'atuin login' first if sync is wanted)"
  fi
done

echo "Replacing demo identity.age with the real one:"
cp "$OLD_REPO/identity.age" "$ROOT/identity.age"
echo "  OK -> identity.age (same passphrase as dotfiles-old)"

echo
echo "Done. Review 'git status'/'git diff --stat' in $ROOT, then commit."
echo "bin/launch-demo no longer depends on the real identity.age (it mints its own throwaway one), so it still runs unaffected."

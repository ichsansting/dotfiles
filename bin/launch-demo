#!/usr/bin/env python3
"""Standalone verification for the full launch chain (ticket 15): fzf preset
pick (bin/launch) -> isolate (12) -> secrets bootstrap (14) -> materialize
(11) -> package assembly (13). Run directly: bin/launch-demo

Builds a throwaway fixture repo (own preset/bundle/fragment tree, symlinked
to this repo's real bin/pkg) with a plain file, a secret file, and a fragment
— all encrypted for a freshly generated, passphrase-protected identity.age
minted just for this run (documented test passphrase below, not real
content) — so the secrets-decrypt and file-write loops are genuinely
exercised without touching the repo's real identity.age or real secrets
(ticket 16 replaced the old demo-only identity.age with the real one).

Two things are checked:
  1. bin/launch-inner's own wiring (secrets bootstrap + materialize + the
     resolved assemble hand-off), driven directly against a plain temp $HOME.
     This is what's new in ticket 15, independent of ticket 12's isolation
     mechanism (already verified standalone by bin/isolate-demo).
  2. The bin/isolate -> bin/launch-inner argument hand-off. A full happy-path
     run (real isolation + a live terminal for the age passphrase prompt)
     can't be driven headlessly — this only confirms isolate's own documented
     loud-failure path, or reports that isolation succeeded and a live
     terminal is needed to go further.
"""
from __future__ import annotations

import importlib.util
import json
import shutil
import subprocess
import sys
import tempfile
from importlib.machinery import SourceFileLoader
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "pkg"))
from dotfiles.testing import with_passphrase  # noqa: E402

PASSPHRASE = "ephemeral-shell-demo-fixture"  # used only for the freshly minted fixture identity


def _load_launch_inner():
    loader = SourceFileLoader("launch_inner", str(ROOT / "bin" / "launch-inner"))
    spec = importlib.util.spec_from_loader("launch_inner", loader)
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


def _make_demo_identity(fixture_root: Path) -> str:
    """Generates a fresh age keypair and passphrase-encrypts it into
    fixture_root/identity.age, returning the recipient public key — fully
    decoupled from the repo's real identity.age (ticket 16)."""
    raw_key = fixture_root / "raw-key.txt"
    subprocess.run(["age-keygen", "-o", str(raw_key)], check=True, capture_output=True)
    recipient = next(
        line.split(":", 1)[1].strip()
        for line in raw_key.read_text().splitlines()
        if "public key:" in line.lower()
    )
    with_passphrase(
        PASSPHRASE,
        subprocess.run,
        ["age", "--passphrase", "--encrypt", "-o", str(fixture_root / "identity.age"), str(raw_key)],
        feed_count=2,
        check=True,
    )
    raw_key.unlink()
    return recipient


def _encrypt_secret(files_dir: Path, name: str, content: bytes, recipient: str) -> None:
    plain = files_dir / f"{name}.plain-tmp"
    plain.write_bytes(content)
    encrypted = subprocess.run(
        [
            "sops",
            "--encrypt",
            "--config",
            "/dev/null",  # ignore any .sops.yaml sops finds via cwd — this fixture supplies its own recipient
            "--age",
            recipient,
            "--input-type",
            "binary",
            "--output-type",
            "binary",
            str(plain),
        ],
        capture_output=True,
        check=True,
    ).stdout
    (files_dir / name).write_bytes(encrypted)
    plain.unlink()


def _make_fixture(fixture_root: Path, recipient: str) -> None:
    (fixture_root / "presets").mkdir(parents=True)
    (fixture_root / "presets" / "demo.json").write_text(
        json.dumps({"bundles": ["demo-bundle"], "settings": {"git": {"email": "demo@example.com"}}})
    )

    files_dir = fixture_root / "bundles" / "demo-bundle" / "files"
    files_dir.mkdir(parents=True)
    (fixture_root / "bundles" / "demo-bundle" / "files.json").write_text(
        json.dumps(
            {
                "files": [
                    {"path": ".plain-file", "mode": "plain"},
                    {"path": ".secret-file", "mode": "secret"},
                    {"path": ".ssh/id_ed25519", "mode": "secret"},
                ]
            }
        )
    )
    (files_dir / ".plain-file").write_text("plain content\n")
    _encrypt_secret(files_dir, ".secret-file", b"demo secret content\n", recipient)

    ssh_dir = files_dir / ".ssh"
    ssh_dir.mkdir()
    demo_key = ssh_dir / "id_ed25519.raw"
    subprocess.run(["ssh-keygen", "-t", "ed25519", "-N", "", "-f", str(demo_key)], capture_output=True, check=True)
    _encrypt_secret(files_dir, ".ssh/id_ed25519", demo_key.read_bytes(), recipient)
    demo_key.unlink()
    demo_key.with_suffix(".raw.pub").unlink()

    frag_dir = fixture_root / "fragments" / ".demo.d"
    frag_dir.mkdir(parents=True)
    (frag_dir / "10-demo-bundle.md").write_text("plain fragment content\n")

    (fixture_root / "bin").symlink_to(ROOT / "bin")
    (fixture_root / "pkg").symlink_to(ROOT / "pkg")


def demo_build_home() -> None:
    launch_inner = _load_launch_inner()

    with tempfile.TemporaryDirectory() as fixture_dir, tempfile.TemporaryDirectory() as home_dir:
        fixture_root = Path(fixture_dir)
        home = Path(home_dir)
        recipient = _make_demo_identity(fixture_root)
        _make_fixture(fixture_root, recipient)

        argv = with_passphrase(PASSPHRASE, launch_inner.build_home, fixture_root, "demo", home)

        checks = [
            (home / ".plain-file", b"plain content\n"),
            (home / ".secret-file", b"demo secret content\n"),
            (home / ".demo", b"plain fragment content\n"),
        ]
        for path, expected in checks:
            if not path.exists():
                print(f"FAIL: {path.name} was not materialized into the ephemeral $HOME")
                sys.exit(1)
            if path.read_bytes() != expected:
                print(f"FAIL: {path.name} has unexpected content: {path.read_bytes()!r}")
                sys.exit(1)

        secret_path = home / ".secret-file"
        if (secret_path.stat().st_mode & 0o777) != 0o600:
            print("FAIL: decrypted secret file has the wrong permissions")
            sys.exit(1)

        key_path = home / ".config" / "sops" / "age" / "keys.txt"
        if not key_path.exists() or (key_path.stat().st_mode & 0o777) != 0o600:
            print("FAIL: identity key was not decrypted into the ephemeral $HOME")
            sys.exit(1)

        pub_path = home / ".ssh" / "id_ed25519.pub"
        if not pub_path.exists() or not pub_path.read_text().startswith("ssh-ed25519 "):
            print("FAIL: ssh pubkey was not derived from the materialized private key")
            sys.exit(1)

        signers_path = home / ".ssh" / "allowed_signers"
        expected_signers = f"demo@example.com {pub_path.read_text()}"
        if not signers_path.exists() or signers_path.read_text() != expected_signers:
            print("FAIL: allowed_signers was not derived correctly")
            sys.exit(1)
        if (signers_path.stat().st_mode & 0o777) != 0o600:
            print("FAIL: allowed_signers has the wrong permissions")
            sys.exit(1)

        expected_argv = [str(fixture_root / "bin" / "assemble"), "demo-bundle"]
        if argv != expected_argv:
            print(f"FAIL: unexpected assemble argv: {argv}")
            sys.exit(1)

        print("OK: identity + secret file decrypted, plain file and composed fragment materialized")
        print("OK: ssh pubkey + allowed_signers derived from the materialized private key")
        print(f"OK: would hand off to: {' '.join(argv)}")


def demo_isolate_handoff() -> None:
    result = subprocess.run(
        [
            str(ROOT / "bin" / "isolate"),
            "--",
            str(ROOT / "bin" / "launch-inner"),
            str(ROOT),
            "personal",
            "--",
            "true",
        ],
        capture_output=True,
        text=True,
    )
    if "unprivileged user namespaces are unavailable" in result.stderr:
        print("OK: isolate -> launch-inner hand-off reached isolate's documented loud-failure path")
        print("    (no unprivileged userns on this host — see bin/isolate-demo, ticket 12)")
        return
    print("isolation succeeded on this host — full run needs a live terminal for the age")
    print("passphrase prompt; run bin/launch-demo interactively (with a real tty) to confirm")


if __name__ == "__main__":
    missing = [t for t in ("age", "age-keygen", "sops", "ssh-keygen") if shutil.which(t) is None]
    if missing:
        print(f"SKIP: {', '.join(missing)} not available")
        sys.exit(0)

    demo_build_home()
    demo_isolate_handoff()
